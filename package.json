{
  "name": "cafelytic",
  "version": "0.0.0",
  "private": true,
  "description": "Coffee water / brew recipe calculator. Vanilla JS, GitHub Pages. This package.json exists only for local type-checking and unit tests — see CLAUDE.md.",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@supabase/supabase-js": "^2.103.3",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^15.15.0",
    "http-server": "^14.1.1",
    "prettier": "^3.8.3",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.58.2",
    "vitest": "^3.2.4"
  }
}
